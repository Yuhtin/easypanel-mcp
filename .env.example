# The panel origin must use HTTPS. Values belong in the MCP host's secret env,
# never in source control or tool arguments.
EASYPANEL_URL=https://panel.example.com
EASYPANEL_TOKEN=replace-in-your-secret-store

# Safe defaults: no mutation and no wildcard project access.
EASYPANEL_ACCESS_MODE=readonly
EASYPANEL_ALLOWED_PROJECTS=sandbox
EASYPANEL_INSTANCE_LABEL=easypanel

# Required only for operator/admin mode. Keep this independent from the panel
# token. A human-side approval CLI signs short-lived plan approvals with it.
# EASYPANEL_APPROVAL_KEY=at-least-32-random-bytes-from-a-secret-store

# Optional transport override: auto | rpc | trpc. The exact version pin is
# mandatory whenever HTTP (rather than the offline fixture) is used.
EASYPANEL_API_FLAVOR=auto
EASYPANEL_EXPECTED_VERSION=2.31.0

# Secret references in service specs resolve from this prefix. For example,
# secretRef DATABASE_URL reads EASYPANEL_SECRET_DATABASE_URL.
EASYPANEL_SECRET_PREFIX=EASYPANEL_SECRET_

# Optional operational settings. Audit/lock files and approval/webhook directories
# must be distinct and non-nested after lexical path resolution.
EASYPANEL_AUDIT_PATH=.state/audit.jsonl
EASYPANEL_AUDIT_ACTOR=mcp-client
EASYPANEL_APPROVAL_DIR=.state/approvals
EASYPANEL_RUNTIME_LOCK_PATH=.state/runtime.lock
# Required before deploy-webhook rotation is advertised or allowed.
# EASYPANEL_WEBHOOK_SINK_DIR=.state/webhook-secrets
EASYPANEL_APPROVAL_TTL_SECONDS=300
EASYPANEL_PLAN_TTL_SECONDS=900
EASYPANEL_TIMEOUT_MS=10000
EASYPANEL_MAX_RESPONSE_BYTES=2097152

# Transport defaults to local stdio. The remote HTTP mode is intentionally
# readonly-only until its approval model is redesigned around an external
# asymmetric signer. It must sit behind an HTTPS reverse proxy; do not publish
# the container port directly.
EASYPANEL_MCP_TRANSPORT=stdio
# Required only when EASYPANEL_MCP_TRANSPORT=http. This is a separate random
# bearer token, never the Easypanel token. Generate and store it as a secret;
# it is deliberately not given a sample value here.
# EASYPANEL_MCP_ACCESS_TOKEN=
# EASYPANEL_MCP_HTTP_PUBLIC_ORIGIN=https://mcp.example.com
# EASYPANEL_MCP_HTTP_BIND_HOST=0.0.0.0
# EASYPANEL_MCP_HTTP_PORT=3000
# EASYPANEL_MCP_HTTP_MAX_REQUEST_BYTES=131072
# EASYPANEL_MCP_HTTP_MAX_SESSIONS=16
# EASYPANEL_MCP_HTTP_MAX_CONCURRENT_REQUESTS=16
# EASYPANEL_MCP_HTTP_REQUEST_TIMEOUT_MS=70000
# EASYPANEL_MCP_HTTP_SESSION_IDLE_SECONDS=900
# EASYPANEL_MCP_HTTP_SESSION_MAX_AGE_SECONDS=3600
# In remote mode EASYPANEL_TIMEOUT_MS may not exceed 10000; the HTTP deadline
# must cover the finite retry/query budget and is validated at startup.

# Test/offline mode only: use the bundled in-memory fixture instead of HTTP. When
# enabled, set EASYPANEL_EXPECTED_VERSION=2.31.0-fake (or omit that variable).
# EASYPANEL_FAKE_FIXTURE=fixtures/easypanel-2.31.json
